{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "venv/Scripts/uvicorn.exe",
      "runtimeArgs": ["app.main:app", "--reload", "--port", "8000"],
      "cwd": "src/backend",
      "port": 8000,
      "autoPort": false
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "src/frontend",
      "port": 5173,
      "autoPort": false
    }
  ]
}
