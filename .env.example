# Green Valley Hospital — environment variable reference
# Copy this file to src/backend/.env and adjust values as needed.
# The backend works with zero configuration on a fresh clone;
# these overrides are only needed when changing defaults.

# ---- Backend (src/backend/.env) ------------------------------------------

# HS256 secret used to sign JWTs. Change to a long random string in any
# non-development environment.
JWT_SECRET_KEY=change-me-to-a-long-random-string

# SQLite database path (absolute or relative to where uvicorn is run from).
# Default: db/green_valley.db inside the project root.
DATABASE_URL=sqlite:////absolute/path/to/db/green_valley.db

# Comma-separated list of allowed CORS origins (no trailing slash).
CORS_ORIGINS=http://localhost:5173

# JWT access-token time-to-live in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---- Frontend (src/frontend/.env.development) ----------------------------
# Already committed with correct defaults. Only override if you change ports.

# Base URL prefix that Vite proxies to the FastAPI backend.
# VITE_API_BASE_URL=/api
